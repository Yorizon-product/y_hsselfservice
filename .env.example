# HubSpot OAuth (Settings > Integrations > Private Apps > Create OAuth App)
HUBSPOT_CLIENT_ID=your-client-id
HUBSPOT_CLIENT_SECRET=your-client-secret
# Self-hosted default. For Vercel set this to https://<project>.vercel.app/api/auth/callback.
HUBSPOT_REDIRECT_URI=https://hsselfservice.cdit-dev.de/api/auth/callback

# Session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=your-32-plus-character-secret-here

# Basic auth (browser password prompt). Leave both unset to disable (local dev).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=your-password-here

# Portal readiness polling (default: on). Set to "off" to disable the wait
# for Yorizon provisioning between company and contact creation.
PORTAL_STATUS_POLL=on

# Debug flag for poll failures. When "1", poll failures do NOT trigger
# rollback — the created company stays in HubSpot for inspection. Leaves
# orphan records; unset after debugging.
# PORTAL_STATUS_POLL_KEEP_ON_FAIL=1

# ─── Self-hosted only (ignored on Vercel) ──────────────────────────────────
# SQLite directory for the jobs table + idempotency keys. Must be writable
# by the app user. The Docker image sets this to /data and bind-mounts it.
DATA_DIR=./data

# In-process job worker. Set to "1" to start the worker when the server
# boots (self-hosted); leave unset/0 to run a read-only frontend (e.g. for
# debugging). The Docker image sets RUN_WORKER=1 by default.
RUN_WORKER=1
