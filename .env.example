# HubSpot OAuth (Settings > Integrations > Private Apps > Create OAuth App)
HUBSPOT_CLIENT_ID=your-client-id
HUBSPOT_CLIENT_SECRET=your-client-secret
HUBSPOT_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback

# Session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=your-32-plus-character-secret-here

# Basic auth (browser password prompt)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=your-password-here

# Portal readiness polling (default: on). Set to "off" to disable the wait
# for Yorizon provisioning between company and contact creation — the route
# falls back to pre-change behaviour (contact created immediately).
PORTAL_STATUS_POLL=on

# Debug flag for poll failures. When set to "1", poll failures do NOT trigger
# rollback — the created company stays in HubSpot so you can inspect it in
# the UI (check notes, timeline, other properties for the failure reason
# Yorizon writes outside portal_status_update). Leaves orphan records on
# failure; unset after debugging.
# PORTAL_STATUS_POLL_KEEP_ON_FAIL=1
